{
  "rules": [
    {
      "name": "GitHub notifications",
      "category": "github",
      "from_contains": "notifications@github.com",
      "action": "archive",
      "target": "GitHub"
    },
    {
      "name": "QQ Mail app promotion",
      "category": "marketing",
      "from_contains": "10000@qq.com",
      "subject_contains": "更安全",
      "action": "archive",
      "target": "Deleted Messages"
    },
    {
      "name": "PayPal marketing",
      "category": "marketing",
      "from_contains": "noreply@news.paypal.com",
      "action": "archive",
      "target": "Deleted Messages"
    },
    {
      "name": "Discord missed messages",
      "category": "notification",
      "from_contains": "noreply@discord.com",
      "action": "archive",
      "target": "Deleted Messages"
    },
    {
      "name": "Newsletter",
      "category": "newsletter",
      "any_from_contains": [
        "substack.com",
        "hackernoon.com",
        "recomendo.com"
      ],
      "action": "review"
    },
    {
      "name": "Marketing subject",
      "category": "marketing",
      "any_subject_contains": [
        "<AD>",
        "推广",
        "优惠",
        "促销"
      ],
      "action": "review"
    }
  ]
}
