{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/echoVic/qqmail-organizer/rules.schema.json",
  "title": "QQMail Organizer Rules",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "minLength": 1
          },
          "from_contains": {
            "type": "string",
            "minLength": 1
          },
          "any_from_contains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "subject": {
            "type": "string",
            "minLength": 1
          },
          "subject_contains": {
            "type": "string",
            "minLength": 1
          },
          "any_subject_contains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "match_category": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "archive",
              "mark-read",
              "mark-unread",
              "review"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        },
        "allOf": [
          {
            "anyOf": [
              {
                "required": [
                  "from"
                ]
              },
              {
                "required": [
                  "from_contains"
                ]
              },
              {
                "required": [
                  "any_from_contains"
                ]
              },
              {
                "required": [
                  "subject"
                ]
              },
              {
                "required": [
                  "subject_contains"
                ]
              },
              {
                "required": [
                  "any_subject_contains"
                ]
              },
              {
                "required": [
                  "match_category"
                ]
              }
            ]
          },
          {
            "if": {
              "properties": {
                "action": {
                  "const": "archive"
                }
              },
              "required": [
                "action"
              ]
            },
            "then": {
              "required": [
                "target"
              ]
            }
          }
        ]
      },
      "default": []
    }
  },
  "required": [
    "rules"
  ]
}
